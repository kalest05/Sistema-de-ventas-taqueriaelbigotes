	<property name="net.sf.jasperreports.print.keep.full.text" value="true"/>
	<property name="net.sf.jasperreports.export.pdf.force.linebreak.policy" value="true"/>
	<parameter name="idPedido" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[SELECT 
            p.idPedido,
            p.fecha,
            dp.cantidad,
            pr.nombre AS nombreProducto,
            pr.precio,
            dp.subtotal,
            p.total
        FROM Pedido p
        INNER JOIN DetallePedido dp ON p.idPedido = dp.idPedido
        INNER JOIN Producto pr ON dp.idProducto = pr.idProducto
        WHERE p.idPedido = $P{idPedido}]]>
	</queryString>
	<field name="idPedido" class="java.lang.Integer"/>
	<field name="fecha" class="java.sql.Timestamp"/>
	<field name="cantidad" class="java.lang.Integer"/>
	<field name="nombreProducto" class="java.lang.String"/>
	<field name="precio" class="java.math.BigDecimal"/>
	<field name="subtotal" class="java.math.BigDecimal"/>
	<field name="total" class="java.math.BigDecimal"/>
	<variable name="TotalGeneral" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{subtotal}]]></variableExpression>
	</variable>
