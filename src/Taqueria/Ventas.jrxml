	<queryString language="SQL">
		<![CDATA[SELECT 
    CAST(GETDATE() AS DATE) AS FechaReporte,
    Corte,
    COUNT(idPedido) AS NumeroPedidos,
    SUM(total) AS VentaTotal,
    CAST(AVG(CAST(total AS DECIMAL(10,2))) AS DECIMAL(10,2)) AS PromedioTicket,
    
    CAST(
        SUM(total) * 100.0 / SUM(SUM(total)) OVER()
        AS DECIMAL(5,2)
    ) AS PorcentajeDelDia,

    -- 🔥 TOTAL DEL DÍA
    SUM(SUM(total)) OVER() AS TotalDia

FROM (
    SELECT 
        idPedido,
        total,
        fecha,
        CASE 
            WHEN DATEPART(HOUR, fecha) >= 8 AND DATEPART(HOUR, fecha) < 15 
                THEN 'Corte 1'
            WHEN DATEPART(HOUR, fecha) >= 15 AND DATEPART(HOUR, fecha) < 24 
                THEN 'Corte 2'
        END AS Corte
    FROM Pedido
    WHERE CAST(fecha AS DATE) = CAST(GETDATE() AS DATE)
) AS SubConsulta

WHERE Corte IS NOT NULL
GROUP BY Corte
ORDER BY Corte;]]>
	</queryString>
